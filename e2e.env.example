# Скопируйте в my-app/.env.e2e и заполните для полного прогона:
#   cd /Users/vladimirchudinov/Desktop/my-startup/my-app
#   cp e2e.env.example .env.e2e

E2E_BASE_URL=https://zeip.ru

# Обычный пользователь (Free) — профиль с городом и профессией
E2E_USER_EMAIL=
# Пароль без пробелов по краям. Если в пароле есть # — возьмите в кавычки: E2E_USER_PASSWORD="pass#word"
E2E_USER_PASSWORD=

# Pro-пользователь (опционально; иначе используется E2E_USER_*)
E2E_PRO_USER_EMAIL=
E2E_PRO_USER_PASSWORD=

# Админ support+ (для /admin/*)
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# UUID чужого профиля для /profiles/[id] (опционально)
E2E_OTHER_PROFILE_ID=
